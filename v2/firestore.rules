rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Admins can read/write everything (role check placeholder)
    // Note: In a real prod environment, you'd check custom claims or an admin collection
    
    // Users can access their own profile
    match /users/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }

    // Students, Classes, Attendance, Assignments: Requires auth
    // Note: To make this robust, we should check specifically if the user is a teacher
    match /classes/{classId} {
      allow read: if isAuthenticated();
      // Only teachers should write
      allow write: if isAuthenticated(); 
    }

    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /assignments/{assignmentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /exams/{examId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Pre-registration requires auth to read, write is admin/teacher only (simplification here)
    match /PreRegisteredUsers/{docId} {
      allow read: if true; // Actually clients checking if they can register need to read it
      allow write: if isAuthenticated();
    }
    
    match /systemLogs/{logId} {
      allow read, write: if isAuthenticated(); // Should be admin only
    }
  }
}
